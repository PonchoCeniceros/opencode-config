{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "ask",
    "write": "allow",
    "skill": "allow",
    "webfetch": "allow"
  },
  "agent": {
    "web-review": {
      "description": "Revisa código web siguiendo mejores prácticas de React, Next.js, NestJS y TypeScript",
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "mobile-dev": {
      "description": "Experto en React Native y Expo para desarrollo móvil",
      "mode": "subagent"
    }
  }
}
